+#if defined(UFM_CUSTOM_KERNELS)
+// FA with INT8 KV (non-paged): kv_stride = HEAD_DIM+2, bs_k/bs_v are byte offsets per batch
+struct vk_fa_kv_quant_push_constants {
+    uint32_t Sq, Skv, Hq, Hkv, D;
+    float    scale;
+    float    logit_softcap;  // 0.0 = disabled; ~50.0 for Gemma 4
+    uint32_t causal;
+    uint32_t kv_stride;          // (D/32)*34 bytes per KV vector (Q8_0 format)
+    uint32_t bs_q, bs_k, bs_v, bs_o;
+};
+// FA with paged KV: block_table uploaded separately to binding 4
+struct vk_fa_paged_push_constants {
+    uint32_t Sq, Skv, Hq, Hkv, D;
+    float    scale;
+    float    logit_softcap;  // 0.0 = disabled; ~50.0 for Gemma 4
+    uint32_t causal;
+    uint32_t kv_stride_per_head;   // HEAD_DIM + 2
+    uint32_t kv_heads_stride;      // kv_stride_per_head * 2
+    uint32_t token_stride;         // n_heads_kv * kv_heads_stride
+    uint32_t bytes_per_phys_block; // PKV_TOKENS_PER_BLOCK * token_stride
+    uint32_t max_block_slots;
+    uint32_t bs_q, bs_o;
+};
+// kvcache update push constants (kvcache_update_q8.glsl)
+struct vk_kvcache_push_constants { uint32_t seq_pos, max_seq, n_heads, head_dim,
+                                              head_idx, layer_idx, cache_stride; };
+// Q4_K fused dequant+WMMA GEMM (linear_coop_q4k.glsl, linear_coop_q4k_silu.glsl)
+struct vk_mul_q4k_push_constants  { uint32_t M, N, K, blocks_per_row; };
+// Q8_0 INT8 WMMA GEMM (linear_coop_q8.glsl)
+struct vk_mul_q8_push_constants   { uint32_t M, N, K, blocks_per_row; };
+// FP16 cooperative matrix GEMM (linear_coop_32.glsl)
+struct vk_mul_f16_push_constants  { uint32_t M, N, K; float alpha; };
+#endif // UFM_CUSTOM_KERNELS

