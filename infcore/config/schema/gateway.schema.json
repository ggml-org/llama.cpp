{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infcore.local/schema/gateway.schema.json",
  "title": "infcore gateway config",
  "type": "object",
  "additionalProperties": false,
  "required": ["server", "models"],
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "port"],
      "properties": {
        "host": { "type": "string", "default": "127.0.0.1" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "metrics_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "max_concurrent_requests": { "type": "integer", "minimum": 1, "default": 8 },
        "request_timeout_ms": { "type": "integer", "minimum": 0, "default": 120000 }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/model" }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authn": { "enum": ["api_key", "mtls", "oidc"], "default": "api_key" },
        "api_keys": { "type": "array", "items": { "type": "string" }, "description": "legacy: плоский список ключей (роль admin)" },
        "rbac_enabled": { "type": "boolean", "default": true },
        "principals": {
          "type": "array",
          "description": "API-ключ -> кто (subject) и роль (role)",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["api_key", "role"],
            "properties": {
              "api_key": { "type": "string" },
              "subject": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        },
        "roles": {
          "type": "array",
          "description": "Роль -> allowlists моделей и эндпоинтов ('*' = любые)",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "allow_models": { "type": "array", "items": { "type": "string" } },
              "allow_endpoints": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sink": { "enum": ["file", "none"], "default": "file" },
            "path": { "type": "string", "description": "Путь к append-only JSONL-журналу" }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics_enabled": { "type": "boolean", "default": true },
        "metrics_path": { "type": "string", "default": "/metrics" }
      }
    },
    "offline": {
      "type": "object",
      "additionalProperties": false,
      "description": "Жёсткий offline-режим: запрет любых исходящих соединений в рантайме.",
      "properties": {
        "enforce_no_egress": { "type": "boolean", "default": true }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "description": "Lazy-подъём управляемых бэкендов (моделей без backend_url).",
      "properties": {
        "llama_server_bin": { "type": "string", "description": "Путь к llama-server из нашей сборки" },
        "port_range_start": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8100 },
        "idle_timeout_ms": { "type": "integer", "minimum": 0, "default": 300000 },
        "startup_timeout_ms": { "type": "integer", "minimum": 0, "default": 120000 }
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_name"],
      "properties": {
        "logical_name": { "type": "string", "pattern": "^[a-z0-9._-]+$" },
        "gguf_path": { "type": "string", "description": "Локальный путь к GGUF (offline)" },
        "arch": { "type": "string", "description": "general.architecture из метаданных GGUF" },
        "backend_url": { "type": "string", "description": "Внешний llama-server; если пусто - бэкенд управляется runtime-supervisor" },
        "upstream_model": { "type": "string", "description": "Имя модели на бэкенде, если отличается от logical_name" },
        "modality": { "enum": ["text", "embedding", "vision", "audio"], "default": "text" },
        "enabled": { "type": "boolean", "default": true },
        "n_ctx": { "type": "integer", "minimum": 512, "default": 8192 },
        "n_gpu_layers": { "type": "integer", "minimum": 0, "default": 0 },
        "mmproj_path": { "type": "string", "description": "Проектор для vision/audio (mtmd), если применимо" }
      }
    }
  }
}
