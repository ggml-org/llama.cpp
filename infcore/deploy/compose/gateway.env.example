# Пример файла секретов для gateway. Скопировать в gateway.env (НЕ коммитить).
# В gateway.yaml ссылаться так: "api_key": "env:INFCORE_KEY_ADMIN".
# Сгенерировать реальные значения, напр.:  openssl rand -hex 32
# (заглушки вида change-me* gateway отвергает на старте).
INFCORE_KEY_ADMIN=REPLACE_ME_WITH_RANDOM_SECRET
INFCORE_KEY_EMBED=REPLACE_ME_WITH_RANDOM_SECRET
